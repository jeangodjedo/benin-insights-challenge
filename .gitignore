# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Virtual environment
venv/
.env/
env/

# Environment variables
.env

# Jupyter
.ipynb_checkpoints/

# Data files - large raw/processed files excluded from git
data/*.csv
data/*.parquet
data/*.xlsx
data/*.json
data/raw/
data/processed/*.csv

# Keep empty data folder
!data/.gitkeep

# External documents and prompts
*.pdf
!reports/*.pdf
reports/PROMPT_GOOGLE_SLIDES.txt

# Tool logs
.blackbox/

# Models — block experimental artifacts but ship the production model
# (required so the Streamlit simulator works on Streamlit Cloud)
models/*
!models/.gitkeep
!models/tone_classifier_rf.pkl
!models/encoder_benin_role.pkl
!models/encoder_event_root.pkl
!models/confusion_matrix_feature_importance.png

# System files
.DS_Store

# Credentials
credentials/
*.json
credentials.json
.idea/.idea/
